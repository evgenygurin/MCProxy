# MCProxy configuration. Copy to `.env` and fill in the providers you use.
# `.env` is git-ignored. Only set credentials for providers you actually have.

# ---- Global server settings (prefix MCPROXY_) ----
MCPROXY_TRANSPORT=stdio          # stdio | http | sse
MCPROXY_HOST=127.0.0.1
MCPROXY_PORT=8000
MCPROXY_REQUEST_TIMEOUT=30
# MCPROXY_DEFAULT_PROVIDER=webshare   # preferred provider for acquire_proxy

# ============================================================
# Implemented providers
# ============================================================

# --- International ---
# Webshare — https://apidocs.webshare.io/  (Authorization: Token <key>)
WEBSHARE_API_KEY=

# IPRoyal (residential) — https://docs.iproyal.com/  (Bearer)
IPROYAL_API_TOKEN=

# ProxyMesh — https://docs.proxymesh.com/  (HTTP Basic)
PROXYMESH_USERNAME=
PROXYMESH_PASSWORD=
# PROXYMESH_SUBACCOUNT=            # sub-account username for usage stats

# ScraperAPI — https://docs.scraperapi.com/  (api_key query param)
SCRAPERAPI_API_KEY=

# ScrapingBee — https://www.scrapingbee.com/documentation/  (api_key query param)
SCRAPINGBEE_API_KEY=

# --- Russian / CIS ---
# Proxy6 — https://proxy6.net/developers  (key in URL path)
PROXY6_API_KEY=

# ProxyLine — https://proxyline.net/api  (API-KEY header)
PROXYLINE_API_KEY=

# Proxy-Store — https://proxy-store.com/en/developers  (key in URL path)
PROXYSTORE_API_KEY=

# Proxy-Seller — https://docs.proxy-seller.com  (key in URL path)
PROXYSELLER_API_KEY=

# ASOCKS — https://api.asocks.com/v2/swagger/docs  (apikey query param)
ASOCKS_API_KEY=

# FineProxy — https://api.fineproxy.org/docs  (HTTP Basic)
FINEPROXY_EMAIL=
FINEPROXY_PASSWORD=

# ============================================================
# Planned providers (adapters not yet implemented; shown by list_providers)
